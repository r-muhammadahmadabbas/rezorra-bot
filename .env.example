# Copy this file to .env and fill in real values. NEVER commit .env.

# mock  -> replies are printed to the console (no Meta account needed)
# cloud -> replies are sent through the real WhatsApp Cloud API
WHATSAPP_MODE=mock

# --- Only needed when WHATSAPP_MODE=cloud ---
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TOKEN=
WHATSAPP_API_VERSION=v21.0

# App Dashboard -> Settings -> Basic -> App Secret
# Used to verify the X-Hub-Signature-256 header on incoming webhooks.
# Leave empty in mock mode to skip signature verification.
META_APP_SECRET=

# Any string you choose. Must match what you type into the Meta webhook setup screen.
WEBHOOK_VERIFY_TOKEN=rezorra_verify_123

# --- Supabase / Postgres (optional). Leave empty to run on offline seed data. ---
# Put the REAL connection string only in your local .env, never here or in git.
# NOTE: Supabase's direct host (db.<ref>.supabase.co:5432) is often IPv6-only.
# If the connection hangs/errors, use the IPv4 "Session pooler" URL from
# Supabase -> Project Settings -> Database -> Connection string -> URI.
# Keep the driver prefix: postgresql+asyncpg://
DATABASE_URL=
